{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/api-spec run codegen && BASE_PATH=/ pnpm --filter @workspace/unseenx run build",
  "outputDirectory": "artifacts/unseenx/dist/public",
  "installCommand": "npm install -g pnpm@10 && pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "/api/chat"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "BASE_PATH": "/"
  }
}
