{
  "version": 2,
  "buildCommand": "npx --yes pnpm@10 --filter @workspace/api-spec run codegen && BASE_PATH=/ npx --yes pnpm@10 --filter @workspace/unseenx run build",
  "outputDirectory": "artifacts/unseenx/dist/public",
  "installCommand": "npx --yes pnpm@10 install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "/api/chat"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "BASE_PATH": "/"
  }
}
